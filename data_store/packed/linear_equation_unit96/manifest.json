{
  "pipeline": "unit-build",
  "mintdim_version": "0.2.1",
  "tokenizer": {
    "type": "hf_json",
    "path": "./md/vocab/json/tokenizer.json",
    "vocab_size": 512,
    "unk_id": 2,
    "pad_id": 0
  },
  "token_storage": {
    "dtype": "uint16",
    "bytes_per_token": 2,
    "magic": 65535
  },
  "sequence_template": [
    "prompt",
    "token_template",
    "target",
    "token_template"
  ],
  "length_field_metadata": "length_field.json",
  "units": {
    "sizes": [
      96
    ],
    "build_batch": 64
  },
  "source": {
    "files": [
      "./md/data/jsonl/linear_equation_uniform_pretrain1000_sft500.jsonl"
    ],
    "fields": [
      [
        "prompt",
        "target"
      ]
    ],
    "templates": [
      "{prompt}\n{target}<eos>"
    ]
  },
  "output": {
    "samples_per_shard": 1500
  }
}